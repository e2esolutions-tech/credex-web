---
const dimensions = [
  {
    name: 'Past',
    weight: '20%',
    color: 'blue',
    colorClass: 'text-blue-400 bg-blue-400/10 border-blue-400/20',
    barColor: 'bg-blue-400',
    description: 'Financial statement analysis, ratio calculations, trend analysis across years of balance sheet data.',
    metrics: ['Debt/Equity', 'Current Ratio', 'ROE', 'ICR', 'Asset Turnover'],
  },
  {
    name: 'Present',
    weight: '25%',
    color: 'emerald',
    colorClass: 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20',
    barColor: 'bg-emerald-400',
    description: 'Real-time credit bureau data, check/note registries, and utility payment patterns.',
    metrics: ['KKB Score', 'Check Bounces', 'Protest Count', 'Utility Payments', 'Payment Regularity'],
  },
  {
    name: 'Future',
    weight: '20%',
    color: 'amber',
    colorClass: 'text-amber-400 bg-amber-400/10 border-amber-400/20',
    barColor: 'bg-amber-400',
    description: 'Sector early warning indices, macroeconomic stress indicators, forward-looking projections.',
    metrics: ['Sector EWI', 'NPL Growth', 'FX Exposure', 'Capacity Utilization', 'Macro Stress'],
  },
  {
    name: 'Behavioral',
    weight: '15%',
    color: 'purple',
    colorClass: 'text-purple-400 bg-purple-400/10 border-purple-400/20',
    barColor: 'bg-purple-400',
    description: 'Employee behavior signals including CV activity, senior management changes, and workforce stability.',
    metrics: ['CV Update Rate', 'Senior Mgmt Changes', 'Dept Concentration', 'Workforce Stability', 'Flight Risk'],
  },
  {
    name: 'Intelligence',
    weight: '20%',
    color: 'rose',
    colorClass: 'text-rose-400 bg-rose-400/10 border-rose-400/20',
    barColor: 'bg-rose-400',
    description: 'OSINT monitoring across news sentiment, social media, darknet exposure, and public regulatory records.',
    metrics: ['News Sentiment', 'Social Signals', 'Darknet Exposure', 'Legal/Regulatory', 'Breach Risk'],
  },
];
---

<section id="model" class="py-20 sm:py-24 lg:py-32 relative overflow-hidden">
  <div class="absolute inset-0 grid-bg opacity-50"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16 lg:mb-20">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-credex-500/10 border border-credex-500/20 mb-4">
        <span class="text-credex-400 text-sm font-medium">The Innovation</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mt-4">
        The <span class="text-credex-400">5D</span> Scoring Model
      </h2>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">
        Traditional credit scoring is 1-dimensional. CredeX sees the full picture through five orthogonal dimensions of risk.
      </p>
    </div>

    <!-- Dimensions -->
    <div class="space-y-6">
      {dimensions.map((dim, i) => (
        <div class="gradient-border p-5 sm:p-6 lg:p-8 hover:bg-surface-700/30 transition-all duration-300">
          <div class="flex flex-col lg:flex-row lg:items-center gap-6">
            <!-- Left: Name & weight -->
            <div class="flex items-center gap-4 lg:w-48 shrink-0">
              <div class={`px-3.5 py-2 sm:px-3 sm:py-1.5 rounded-lg border text-base sm:text-sm font-bold ${dim.colorClass}`}>
                {dim.weight}
              </div>
              <h3 class="text-2xl sm:text-xl font-bold text-white">{dim.name}</h3>
            </div>

            <!-- Middle: Description -->
            <div class="flex-1">
              <p class="text-gray-400 text-base sm:text-sm leading-relaxed">{dim.description}</p>
              <div class="flex flex-wrap gap-2 mt-3">
                {dim.metrics.map(m => (
                  <span class="px-2.5 py-1 sm:px-2 sm:py-0.5 bg-white/5 rounded text-sm sm:text-xs text-gray-500 font-mono">{m}</span>
                ))}
              </div>
            </div>

            <!-- Right: Score bar -->
            <div class="lg:w-48 shrink-0">
              <div class="flex items-center gap-3">
                <div class="flex-1 h-2 bg-surface-700 rounded-full overflow-hidden">
                  <div class={`h-full rounded-full score-fill ${dim.barColor}`} style={`width: ${parseInt(dim.weight)}%; animation-delay: ${i * 200}ms`}></div>
                </div>
                <span class="text-sm font-mono text-gray-400">{dim.weight}</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Formula -->
    <div class="mt-12 text-center">
      <div class="inline-block gradient-border p-6 lg:p-8">
        <p class="text-sm sm:text-xs text-gray-500 uppercase tracking-wider mb-3">Composite Score Formula</p>
        <code class="text-base sm:text-sm lg:text-base font-mono leading-relaxed">
          <span class="text-credex-400">Score</span>
          <span class="text-gray-500"> = </span>
          <span class="text-blue-400">Past</span><span class="text-gray-600">(.20)</span>
          <span class="text-gray-500"> + </span>
          <span class="text-emerald-400">Present</span><span class="text-gray-600">(.25)</span>
          <span class="text-gray-500"> + </span>
          <span class="text-amber-400">Future</span><span class="text-gray-600">(.20)</span>
          <span class="text-gray-500"> + </span>
          <span class="text-purple-400">Behavioral</span><span class="text-gray-600">(.15)</span>
          <span class="text-gray-500"> + </span>
          <span class="text-rose-400">Intelligence</span><span class="text-gray-600">(.20)</span>
        </code>
      </div>
    </div>
  </div>
</section>
