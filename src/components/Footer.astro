---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <!-- Logo -->
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 rounded bg-gradient-to-br from-credex-400 to-credex-600 flex items-center justify-center">
          <span class="text-surface-950 font-bold text-xs">CX</span>
        </div>
        <span class="text-sm font-semibold text-gray-400">Crede<span class="text-credex-400">X</span></span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm text-gray-500">
        <a href="#features" class="hover:text-gray-300 transition-colors">Features</a>
        <a href="#model" class="hover:text-gray-300 transition-colors">5D Model</a>
        <a href="#pricing" class="hover:text-gray-300 transition-colors">Pricing</a>
        <a href="#contact" class="hover:text-gray-300 transition-colors">Contact</a>
      </div>

      <!-- Copyright -->
      <div class="text-sm text-gray-600">
        &copy; {year} <a href="https://e2esolutions.tech" target="_blank" class="hover:text-gray-400 transition-colors">E2E Solutions</a>. All rights reserved.
      </div>
    </div>
  </div>
</footer>
