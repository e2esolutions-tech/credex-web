---
const features = [
  {
    icon: `<svg style="width:clamp(1.75rem,1.5rem+1vw,2rem);height:clamp(1.75rem,1.5rem+1vw,2rem)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`,
    title: 'Multi-Dimensional Scoring',
    description: 'Industry-first 5D scoring model that analyzes credit risk from every possible angle, not just financial statements.',
  },
  {
    icon: `<svg style="width:clamp(1.75rem,1.5rem+1vw,2rem);height:clamp(1.75rem,1.5rem+1vw,2rem)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    title: 'Real-Time Intelligence',
    description: 'OSINT-powered monitoring across news, social media, darknet, and public records for continuous risk assessment.',
  },
  {
    icon: `<svg style="width:clamp(1.75rem,1.5rem+1vw,2rem);height:clamp(1.75rem,1.5rem+1vw,2rem)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>`,
    title: 'Bank-Grade Security',
    description: 'Argon2id hashing, JWT auth, RBAC, full audit logging, and KVKK/GDPR compliance built into every layer.',
  },
  {
    icon: `<svg style="width:clamp(1.75rem,1.5rem+1vw,2rem);height:clamp(1.75rem,1.5rem+1vw,2rem)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>`,
    title: 'Multi-Tenant Architecture',
    description: 'Complete tenant isolation with dedicated data scoping. Serve multiple organizations from a single deployment.',
  },
  {
    icon: `<svg style="width:clamp(1.75rem,1.5rem+1vw,2rem);height:clamp(1.75rem,1.5rem+1vw,2rem)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
    title: 'Advanced Reporting',
    description: 'Auto-generated PDF reports, scheduled exports, email alerts on score changes, and webhook integrations.',
  },
  {
    icon: `<svg style="width:clamp(1.75rem,1.5rem+1vw,2rem);height:clamp(1.75rem,1.5rem+1vw,2rem)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>`,
    title: 'Connector Ecosystem',
    description: 'Pre-built connectors for KKB, check/note registries, utility providers, Kariyer.net, and OSINT sources.',
  },
];
---

<section id="features" class="py-20 sm:py-24 lg:py-32 relative">
  <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16 lg:mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-credex-500/10 border border-credex-500/20 mb-4">
        <span class="text-credex-400 fluid-caption font-medium">Core Capabilities</span>
      </div>
      <h2 class="fluid-heading-lg font-bold text-white mt-4">
        Enterprise-Grade, <span class="text-credex-400">By Design</span>
      </h2>
      <p class="mt-4 fluid-body-lg text-gray-400 max-w-2xl mx-auto">
        Every component built for financial institutions that demand accuracy, security, and reliability.
      </p>
    </div>

    <!-- Feature cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
      {features.map((feature, i) => (
        <div class="gradient-border p-6 sm:p-6 lg:p-8 hover:bg-surface-700/50 transition-all duration-300 group" style={`animation-delay: ${i * 100}ms`}>
          <div class="fluid-icon-lg rounded-xl bg-credex-500/10 flex items-center justify-center text-credex-400 group-hover:bg-credex-500/20 transition-colors" set:html={feature.icon} />
          <h3 class="mt-5 fluid-heading-md font-semibold text-white">{feature.title}</h3>
          <p class="mt-3 text-gray-400 fluid-body">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
