---
const stack = [
  { name: 'FastAPI', desc: 'Async Python backend', category: 'Backend' },
  { name: 'React 18', desc: 'TypeScript frontend', category: 'Frontend' },
  { name: 'PostgreSQL', desc: 'TimescaleDB extension', category: 'Database' },
  { name: 'Redis', desc: 'Caching & queues', category: 'Cache' },
  { name: 'Celery', desc: 'Async task processing', category: 'Workers' },
  { name: 'Docker', desc: 'Container orchestration', category: 'Deploy' },
];

const screens = [
  {
    title: 'Portfolio Dashboard',
    desc: 'Bloomberg-style real-time overview of your entire credit portfolio with risk distribution, sector heatmaps, and activity feeds.',
  },
  {
    title: 'Company Deep-Dive',
    desc: '5D radar chart breakdown, score history timeline, dimension drill-down, and financial ratio analysis for each entity.',
  },
  {
    title: 'Intelligence Monitor',
    desc: 'Live news sentiment, social media signals, darknet exposure alerts, and regulatory event timeline in one view.',
  },
];
---

<section id="platform" class="py-20 sm:py-24 lg:py-32 relative bg-surface-900/50">
  <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16 lg:mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-credex-500/10 border border-credex-500/20 mb-4">
        <span class="text-credex-400 fluid-caption font-medium">The Platform</span>
      </div>
      <h2 class="fluid-heading-lg font-bold text-white mt-4">
        Built for <span class="text-credex-400">Scale</span>
      </h2>
      <p class="mt-4 fluid-body-lg text-gray-400 max-w-2xl mx-auto">
        Modern architecture designed for financial institutions that need reliability, performance, and security.
      </p>
    </div>

    <!-- Dashboard mockup -->
    <div class="gradient-border p-1 mb-16 glow-green">
      <div class="bg-surface-900 rounded-[0.875rem] p-4 lg:p-8">
        <!-- Mock dashboard top bar -->
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
            <div class="w-3 h-3 rounded-full bg-amber-500/60"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
          </div>
          <div class="fluid-caption text-gray-600 font-mono">credex-app.e2esolutions.tech</div>
          <div></div>
        </div>

        <!-- Mock dashboard content -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 mb-6">
          {[
            { label: 'Total Companies', value: '2,847', change: '+12%' },
            { label: 'Avg Score', value: '73.2', change: '+2.1' },
            { label: 'High Risk', value: '156', change: '-8%' },
            { label: 'Portfolio Health', value: '91%', change: '+3%' },
          ].map(card => (
            <div class="bg-surface-800 rounded-lg p-3 sm:p-4 border border-white/5">
              <div class="fluid-caption text-gray-500 mb-1">{card.label}</div>
              <div style="font-size:clamp(1.25rem,1rem+1.2vw,1.5rem)" class="font-bold text-white">{card.value}</div>
              <div class="fluid-caption text-credex-400 mt-1">{card.change}</div>
            </div>
          ))}
        </div>

        <!-- Mock chart area -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="sm:col-span-2 bg-surface-800 rounded-lg p-4 border border-white/5 fluid-chart flex items-end gap-1">
            {Array.from({ length: 24 }, (_, i) => (
              <div class="flex-1 rounded-t" style={`height: ${30 + Math.sin(i * 0.5) * 20 + Math.random() * 40}%; background: linear-gradient(to top, rgba(34,197,94,0.3), rgba(34,197,94,0.1));`}></div>
            ))}
          </div>
          <div class="bg-surface-800 rounded-lg p-4 border border-white/5 fluid-chart">
            <div class="fluid-caption text-gray-500 mb-3">Risk Distribution</div>
            <div class="space-y-3 sm:space-y-2">
              {[
                { label: 'AAA-AA', pct: 35, color: 'bg-emerald-400' },
                { label: 'A-BBB', pct: 28, color: 'bg-credex-400' },
                { label: 'BB-B', pct: 22, color: 'bg-amber-400' },
                { label: 'CCC-D', pct: 15, color: 'bg-rose-400' },
              ].map(item => (
                <div>
                  <div class="flex justify-between fluid-caption mb-1">
                    <span class="text-gray-400">{item.label}</span>
                    <span class="text-gray-500">{item.pct}%</span>
                  </div>
                  <div class="h-2.5 sm:h-1.5 bg-surface-700 rounded-full">
                    <div class={`h-full rounded-full ${item.color}`} style={`width: ${item.pct}%`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Screen descriptions -->
    <div class="grid lg:grid-cols-3 gap-5 sm:gap-6 mb-16">
      {screens.map(screen => (
        <div class="gradient-border p-6">
          <h3 class="fluid-heading-md font-semibold text-white mb-2">{screen.title}</h3>
          <p class="fluid-body text-gray-400">{screen.desc}</p>
        </div>
      ))}
    </div>

    <!-- Tech stack -->
    <div class="text-center mb-8">
      <h3 class="fluid-heading-md font-semibold text-gray-300">Technology Stack</h3>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
      {stack.map(tech => (
        <div class="text-center p-4 rounded-xl bg-surface-800/50 border border-white/5 hover:border-credex-500/20 transition-colors">
          <div class="fluid-body font-semibold text-white">{tech.name}</div>
          <div class="fluid-caption text-gray-500 mt-1">{tech.desc}</div>
        </div>
      ))}
    </div>
  </div>
</section>
