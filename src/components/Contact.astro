---
---

<section id="contact" class="py-24 lg:py-32 relative bg-surface-900/50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-credex-500/10 border border-credex-500/20 mb-4">
        <span class="text-credex-400 text-sm font-medium">Get In Touch</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mt-4">
        Ready to <span class="text-credex-400">Transform</span> Your Risk Assessment?
      </h2>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">
        Schedule a personalized demo and see how 5D scoring can enhance your credit decisions.
      </p>
    </div>

    <!-- Contact form -->
    <div class="gradient-border p-8 lg:p-12">
      <form id="contact-form" class="space-y-6">
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Full Name</label>
            <input type="text" name="name" required
              class="w-full px-4 py-3 bg-surface-900 border border-white/10 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-credex-500/50 focus:ring-1 focus:ring-credex-500/20 transition-colors"
              placeholder="John Smith" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Work Email</label>
            <input type="email" name="email" required
              class="w-full px-4 py-3 bg-surface-900 border border-white/10 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-credex-500/50 focus:ring-1 focus:ring-credex-500/20 transition-colors"
              placeholder="john@company.com" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Company</label>
            <input type="text" name="company" required
              class="w-full px-4 py-3 bg-surface-900 border border-white/10 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-credex-500/50 focus:ring-1 focus:ring-credex-500/20 transition-colors"
              placeholder="Acme Financial" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Organization Type</label>
            <select name="type" required
              class="w-full px-4 py-3 bg-surface-900 border border-white/10 rounded-xl text-white focus:outline-none focus:border-credex-500/50 focus:ring-1 focus:ring-credex-500/20 transition-colors">
              <option value="" class="bg-surface-800">Select...</option>
              <option value="bank" class="bg-surface-800">Bank</option>
              <option value="factoring" class="bg-surface-800">Factoring Company</option>
              <option value="insurance" class="bg-surface-800">Insurance</option>
              <option value="fintech" class="bg-surface-800">Fintech</option>
              <option value="other" class="bg-surface-800">Other</option>
            </select>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Message</label>
          <textarea name="message" rows="4"
            class="w-full px-4 py-3 bg-surface-900 border border-white/10 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-credex-500/50 focus:ring-1 focus:ring-credex-500/20 transition-colors resize-none"
            placeholder="Tell us about your credit risk assessment needs..."></textarea>
        </div>

        <button type="submit"
          class="w-full sm:w-auto px-8 py-4 bg-credex-500 hover:bg-credex-600 text-surface-950 font-bold text-base rounded-xl transition-all duration-200 hover:shadow-xl hover:shadow-credex-500/25">
          Request Demo
        </button>
      </form>

      <div id="form-success" class="hidden text-center py-12">
        <div class="w-16 h-16 mx-auto rounded-full bg-credex-500/10 flex items-center justify-center mb-4">
          <svg class="w-8 h-8 text-credex-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white">Thank You!</h3>
        <p class="text-gray-400 mt-2">We'll be in touch within 24 hours to schedule your demo.</p>
      </div>
    </div>

    <!-- Contact info -->
    <div class="grid sm:grid-cols-3 gap-6 mt-8">
      <div class="text-center p-4">
        <div class="text-sm font-medium text-gray-300">Email</div>
        <a href="mailto:info@e2esolutions.tech" class="text-sm text-credex-400 hover:text-credex-300 transition-colors">info@e2esolutions.tech</a>
      </div>
      <div class="text-center p-4">
        <div class="text-sm font-medium text-gray-300">Website</div>
        <a href="https://e2esolutions.tech" target="_blank" class="text-sm text-credex-400 hover:text-credex-300 transition-colors">e2esolutions.tech</a>
      </div>
      <div class="text-center p-4">
        <div class="text-sm font-medium text-gray-300">Location</div>
        <span class="text-sm text-gray-400">Istanbul, Turkey</span>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.style.display = 'none';
    success?.classList.remove('hidden');
  });
</script>
