---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden grid-bg">
  <!-- Background effects -->
  <div class="absolute inset-0">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-credex-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-credex-400/3 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-20">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Copy -->
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-credex-500/10 border border-credex-500/20 mb-8">
          <span class="w-2 h-2 rounded-full bg-credex-400 animate-pulse"></span>
          <span class="text-credex-400 text-sm font-medium">Next-Gen Credit Intelligence</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-black leading-[1.1] tracking-tight">
          <span class="text-white">Credit Risk,</span><br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-credex-400 to-credex-300 glow-text">
            Redefined in 5D
          </span>
        </h1>

        <p class="mt-6 text-lg lg:text-xl text-gray-400 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          Go beyond traditional scoring. CredeX analyzes <strong class="text-gray-200">Past</strong>,
          <strong class="text-gray-200">Present</strong>, <strong class="text-gray-200">Future</strong>,
          <strong class="text-gray-200">Behavioral</strong>, and <strong class="text-gray-200">Intelligence</strong>
          dimensions for the most comprehensive credit risk assessment available.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="#contact" class="px-8 py-4 bg-credex-500 hover:bg-credex-600 text-surface-950 font-bold text-base rounded-xl transition-all duration-200 hover:shadow-xl hover:shadow-credex-500/25 hover:-translate-y-0.5">
            Request a Demo
          </a>
          <a href="#model" class="px-8 py-4 border border-white/10 hover:border-credex-500/30 text-white font-semibold text-base rounded-xl transition-all duration-200 hover:bg-white/5">
            Explore 5D Model
          </a>
        </div>

        <!-- Trust badges -->
        <div class="mt-12 flex items-center gap-8 justify-center lg:justify-start text-sm text-gray-500">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-credex-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" /></svg>
            Bank-Grade Security
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-credex-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            KVKK Compliant
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-credex-500" fill="currentColor" viewBox="0 0 20 20"><path d="M3 12v3c0 1.657 3.134 3 7 3s7-1.343 7-3v-3c0 1.657-3.134 3-7 3s-7-1.343-7-3z" /><path d="M3 7v3c0 1.657 3.134 3 7 3s7-1.343 7-3V7c0 1.657-3.134 3-7 3S3 8.657 3 7z" /><path d="M17 5c0 1.657-3.134 3-7 3S3 6.657 3 5s3.134-3 7-3 7 1.343 7 3z" /></svg>
            Multi-Tenant SaaS
          </div>
        </div>
      </div>

      <!-- Right: Score visualization -->
      <div class="relative flex justify-center float">
        <div class="relative w-80 h-80 sm:w-96 sm:h-96">
          <!-- Radar rings -->
          <div class="absolute inset-0 rounded-full border border-credex-500/10 pulse-ring"></div>
          <div class="absolute inset-6 rounded-full border border-credex-500/15 pulse-ring" style="animation-delay: 0.5s"></div>
          <div class="absolute inset-12 rounded-full border border-credex-500/20 pulse-ring" style="animation-delay: 1s"></div>
          <div class="absolute inset-18 rounded-full border border-credex-500/25 pulse-ring" style="animation-delay: 1.5s"></div>

          <!-- Center score -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center">
              <div class="text-6xl sm:text-7xl font-black text-credex-400 glow-text count-up">87</div>
              <div class="text-sm text-gray-400 mt-1 font-medium tracking-wider uppercase">Composite Score</div>
              <div class="mt-2 px-3 py-1 bg-credex-500/10 rounded-full text-credex-400 text-xs font-semibold">AA+</div>
            </div>
          </div>

          <!-- Dimension labels floating around -->
          <div class="absolute top-4 left-1/2 -translate-x-1/2 px-3 py-1.5 bg-surface-800/80 backdrop-blur rounded-lg border border-white/5 text-xs text-gray-300">
            <span class="text-blue-400 font-semibold">Past</span> 82
          </div>
          <div class="absolute top-1/4 right-0 px-3 py-1.5 bg-surface-800/80 backdrop-blur rounded-lg border border-white/5 text-xs text-gray-300">
            <span class="text-emerald-400 font-semibold">Present</span> 91
          </div>
          <div class="absolute bottom-1/4 right-2 px-3 py-1.5 bg-surface-800/80 backdrop-blur rounded-lg border border-white/5 text-xs text-gray-300">
            <span class="text-amber-400 font-semibold">Future</span> 78
          </div>
          <div class="absolute bottom-1/4 left-0 px-3 py-1.5 bg-surface-800/80 backdrop-blur rounded-lg border border-white/5 text-xs text-gray-300">
            <span class="text-purple-400 font-semibold">Behavioral</span> 85
          </div>
          <div class="absolute bottom-4 left-1/2 -translate-x-1/2 px-3 py-1.5 bg-surface-800/80 backdrop-blur rounded-lg border border-white/5 text-xs text-gray-300">
            <span class="text-rose-400 font-semibold">Intelligence</span> 92
          </div>

          <!-- Sweep line -->
          <div class="absolute inset-0 radar-sweep" style="transform-origin: center center">
            <div class="absolute top-1/2 left-1/2 w-1/2 h-0.5 bg-gradient-to-r from-credex-400/50 to-transparent origin-left"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-gray-500">
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-gray-500 to-transparent animate-pulse"></div>
  </div>
</section>
